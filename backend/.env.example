# Local runtime
# Docker Compose already provides these values. Use this file when running
# the Phoenix app directly outside Compose.
PHX_SERVER=true
PORT=4000
DATABASE_URL=ecto://postgres:postgres@localhost/boton_backend_dev
POOL_SIZE=10

# Generate a real value for production with: mix phx.gen.secret
SECRET_KEY_BASE=dev-secret-key-base-change-me-dev-secret-key-base-change-me

# Replace these in production.
JWT_SIGNING_SECRET=dev-jwt-signing-secret-change-me
TOKEN_HASH_SECRET=dev-token-hash-secret-change-me

# SMS delivery
# Use "console" for local development or "twilio" for real SMS.
SMS_PROVIDER=console

# Required only when SMS_PROVIDER=twilio
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM_NUMBER=

# Production/release settings
PHX_HOST=example.com
DNS_CLUSTER_QUERY=
ECTO_IPV6=false

# Optional test overrides
DATABASE_HOST=localhost
DATABASE_NAME=boton_backend_test
